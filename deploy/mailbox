#!/usr/bin/env bash
# mailbox — manage Dovecot + Postfix virtual mailboxes on shopifygmc.com.
#
#   mailbox add EMAIL [PASSWORD]   create a mailbox (random pw if omitted)
#   mailbox passwd EMAIL [PASSWORD]   change password (random pw if omitted)
#   mailbox del EMAIL              delete a mailbox + its Maildir
#   mailbox alias FROM TO          alias FROM → TO (TO can be a real
#                                  mailbox, an external address, or another
#                                  alias)
#   mailbox unalias FROM           remove an alias
#   mailbox list                   list mailboxes + aliases
#   mailbox quota EMAIL [SIZE]     set per-mailbox quota (1G, 500M, 0=unlimited;
#                                  empty = remove override → falls back to default)
#   mailbox usage [EMAIL]          print TSV email<TAB>used_bytes<TAB>quota_bytes
#                                  (one line per mailbox, or just EMAIL if given)
#   mailbox recalc EMAIL           wraps doveadm quota recalc — repairs maildirsize
#   mailbox suspend EMAIL          reject auth (mail still delivers; data preserved)
#   mailbox unsuspend EMAIL        re-enable auth
set -euo pipefail

DOMAIN_RE='^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$'
USERS=/etc/dovecot/users
VMAILBOX=/etc/postfix/vmailbox
VIRTUAL=/etc/postfix/virtual
VMAIL_BASE=/var/mail/vmail
DEFAULT_QUOTA=1G   # cPanel-default-style 1GB; admin can override per-mailbox

require_root() {
  [ "$EUID" -eq 0 ] || { echo "must run as root"; exit 1; }
}
require_email() {
  [[ "$1" =~ $DOMAIN_RE ]] || { echo "not a valid email: $1"; exit 1; }
}
gen_pw() {
  openssl rand -base64 27 | tr -d '/+=' | tr -d 'O0Il' | cut -c1-24
}
local_part() { echo "$1" | cut -d@ -f1; }
domain_of()  { echo "$1" | cut -d@ -f2; }

# parse_size_to_bytes "1G" → 1073741824, "500M" → 524288000, "0" → 0
parse_size_to_bytes() {
  local s="${1:-}"
  [ -z "$s" ] && { echo 0; return; }
  case "$s" in
    *[Kk]) echo $(( ${s%[Kk]} * 1024 )) ;;
    *[Mm]) echo $(( ${s%[Mm]} * 1024 * 1024 )) ;;
    *[Gg]) echo $(( ${s%[Gg]} * 1024 * 1024 * 1024 )) ;;
    *[Tt]) echo $(( ${s%[Tt]} * 1024 * 1024 * 1024 * 1024 )) ;;
    *)     echo "$s" ;;
  esac
}

# extract_quota_size <user line> — pulls the SIZE token from
# "userdb_quota_rule=*:storage=1G" and prints "1G"; empty if not set.
extract_quota_size() {
  local line="$1"
  if [[ "$line" =~ userdb_quota_rule=\*:storage=([0-9]+[KMGTkmgt]?) ]]; then
    echo "${BASH_REMATCH[1]}"
  fi
}

# Compose a line's 8th field. If $1 is non-empty, sets the quota rule;
# if empty, no rule (Dovecot's plugin defaults apply).
quota_field_for() {
  local size="${1:-}"
  # Empty → no override (mailbox falls back to system default).
  # "0" → explicit unlimited rule (Dovecot reads 0 as no cap).
  # Anything else → literal storage rule.
  if [ -z "$size" ]; then
    echo ""
  else
    echo "userdb_quota_rule=*:storage=$size"
  fi
}

# Suspend tokens live alongside quota rules in the 8th field.
# Two markers cooperate: `nopassword=y` is the human-readable signal (also
# what the Go reader's regex matches to render the badge), and
# `prior_hash=<original>` carries the real Argon2id hash so unsuspend can
# restore it. The actual auth-block is field 2 (the password hash) being
# rewritten to a sentinel that no Argon2id verifier will ever accept.
SUSPEND_TOKEN='nopassword=y'
# Sentinel hash for suspended accounts. `{ARGON2ID}!` parses as the ARGON2ID
# scheme but the body `!` is invalid PHC encoding, so password::verify always
# returns false. Any submitted password fails — auth is genuinely rejected.
SUSPEND_HASH_SENTINEL='{ARGON2ID}!'

is_suspended_line() {
  local line="$1"
  [[ "$line" == *"$SUSPEND_TOKEN"* ]]
}

# add_suspend_token <existing 8th-field value> — appends nopassword=y if absent.
add_suspend_token() {
  local extra="${1:-}"
  if [[ "$extra" == *"$SUSPEND_TOKEN"* ]]; then
    echo "$extra"; return
  fi
  if [ -z "$extra" ]; then
    echo "$SUSPEND_TOKEN"
  else
    echo "$extra $SUSPEND_TOKEN"
  fi
}

# strip_suspend_token <existing 8th-field value> — removes nopassword=y, then
# normalises whitespace so a stray double-space doesn't sneak back in.
strip_suspend_token() {
  local extra="${1:-}"
  extra="${extra//$SUSPEND_TOKEN/}"
  extra="$(echo "$extra" | tr -s ' ' | sed 's/^ //; s/ $//')"
  echo "$extra"
}

cmd_add() {
  local email="${1:?email required}" pw="${2:-}"
  require_email "$email"
  local local=$(local_part "$email") domain=$(domain_of "$email")
  if grep -q "^$email:" "$USERS"; then
    echo "already exists: $email (use 'mailbox passwd' to change)"; exit 1
  fi
  [ -z "$pw" ] && pw=$(gen_pw)

  local hash; hash=$(doveadm pw -s ARGON2ID -p "$pw")
  local extra; extra=$(quota_field_for "$DEFAULT_QUOTA")
  echo "$email:$hash:5000:5000::$VMAIL_BASE/$domain/$local::$extra" >> "$USERS"
  install -d -o vmail -g vmail -m 0700 "$VMAIL_BASE/$domain/$local"

  echo "$email    $domain/$local/" >> "$VMAILBOX"
  postmap "$VMAILBOX"

  echo "ok: $email created"
  echo "    password: $pw"
  echo "    quota:    $DEFAULT_QUOTA"
  echo "    (record the password — not retrievable later)"
}

cmd_passwd() {
  local email="${1:?email required}" pw="${2:-}"
  require_email "$email"
  local existing; existing=$(grep "^$email:" "$USERS" || true)
  [ -n "$existing" ] || { echo "no such mailbox: $email"; exit 1; }
  [ -z "$pw" ] && pw=$(gen_pw)
  local hash; hash=$(doveadm pw -s ARGON2ID -p "$pw")

  # Preserve the existing 8th-field (quota override etc.) across rotation —
  # otherwise rotating a password silently erases per-mailbox quota.
  local prior_extra; prior_extra=$(printf '%s\n' "$existing" | awk -F: 'BEGIN{OFS=":"} {n=NF; out=$8; for(i=9;i<=n;i++) out=out":"$i; print out}')
  local local=$(local_part "$email") domain=$(domain_of "$email")

  sed -i "\|^$email:|d" "$USERS"
  echo "$email:$hash:5000:5000::$VMAIL_BASE/$domain/$local::$prior_extra" >> "$USERS"
  echo "ok: password rotated for $email"
  echo "    new password: $pw"
}

cmd_del() {
  local email="${1:?email required}"
  require_email "$email"
  read -p "permanently delete $email and its mail? [type the email to confirm] " confirm
  [ "$confirm" = "$email" ] || { echo "aborted"; exit 1; }
  local local=$(local_part "$email") domain=$(domain_of "$email")
  sed -i "\|^$email:|d" "$USERS"
  sed -i "\|^$email\\s|d" "$VMAILBOX"
  postmap "$VMAILBOX"
  rm -rf "$VMAIL_BASE/$domain/$local"
  echo "ok: $email deleted"
}

cmd_alias() {
  local from="${1:?from required}" to="${2:?to required}"
  require_email "$from"
  # Remove old entry if present, then append
  sed -i "\|^$from\\s|d" "$VIRTUAL"
  echo "$from    $to" >> "$VIRTUAL"
  postmap "$VIRTUAL"
  echo "ok: $from → $to"
}

cmd_unalias() {
  local from="${1:?from required}"
  sed -i "\|^$from\\s|d" "$VIRTUAL"
  postmap "$VIRTUAL"
  echo "ok: removed alias for $from"
}

cmd_list() {
  echo "=== mailboxes ==="
  awk -F: '{print "  " $1}' "$USERS" | sort
  echo ""
  echo "=== aliases ==="
  awk 'NF==2 {printf "  %-35s → %s\n", $1, $2}' "$VIRTUAL" | sort
}

# --- quota / usage / recalc -------------------------------------------------

cmd_quota() {
  local email="${1:?email required}" size="${2:-}"
  require_email "$email"
  local existing; existing=$(grep "^$email:" "$USERS" || true)
  [ -n "$existing" ] || { echo "no such mailbox: $email"; exit 1; }

  # Validate size syntax: digits + optional K/M/G/T, or 0, or empty
  if [ -n "$size" ] && [ "$size" != "0" ] && ! [[ "$size" =~ ^[0-9]+[KMGTkmgt]?$ ]]; then
    echo "bad size: $size (use 1G, 500M, 2K, 0=unlimited, or empty=default)"; exit 1
  fi

  # Rebuild the line's 8th field with the new quota rule, preserving the
  # rest of the line via awk.
  local extra; extra=$(quota_field_for "$size")
  local rebuilt; rebuilt=$(printf '%s\n' "$existing" | awk -F: -v ex="$extra" 'BEGIN{OFS=":"} { print $1,$2,$3,$4,$5,$6,$7,ex }')

  sed -i "\|^$email:|d" "$USERS"
  echo "$rebuilt" >> "$USERS"

  # Force Dovecot to pick up the new rule + recalc the mailbox's usage so
  # the next read sees the correct ratio.
  doveadm reload >/dev/null 2>&1 || true
  doveadm quota recalc -u "$email" 2>/dev/null || true

  echo "ok: quota for $email = ${size:-default ($DEFAULT_QUOTA)}"
}

# Read the maildirsize file and return the integer used-bytes.
# Dovecot maildirsize format:
#   line 1: <quota_bytes>S[<quota_count>C]   ← QUOTA header, not usage
#   line 2+: <bytes> <msgs>                  ← absolute baseline (after recalc)
#            +<add_bytes> <add_msgs>         ← deltas on delivery
#            -<sub_bytes> <sub_msgs>         ← deltas on expunge
# We SKIP line 1 (it's the quota cap, not a usage value) and sum the leading
# signed integer of each subsequent line.
maildirsize_used_bytes() {
  local path="$1"
  [ -f "$path" ] || { echo 0; return; }
  awk 'BEGIN { used = 0 }
       NR==1 { next }
       NF>=1 { used += $1 }
       END   { print (used<0) ? 0 : used+0 }' "$path"
}

cmd_usage() {
  local one="${1:-}"
  emit_one() {
    local email="$1"
    local local=$(local_part "$email") domain=$(domain_of "$email")
    local user_line; user_line=$(grep "^$email:" "$USERS" || true)
    local size_token; size_token=$(extract_quota_size "$user_line")
    [ -z "$size_token" ] && size_token="$DEFAULT_QUOTA"
    local quota_bytes; quota_bytes=$(parse_size_to_bytes "$size_token")
    local used; used=$(maildirsize_used_bytes "$VMAIL_BASE/$domain/$local/maildirsize")
    printf '%s\t%s\t%s\n' "$email" "$used" "$quota_bytes"
  }

  if [ -n "$one" ]; then
    require_email "$one"
    grep -q "^$one:" "$USERS" || { echo "no such mailbox: $one"; exit 1; }
    emit_one "$one"
  else
    awk -F: '{print $1}' "$USERS" | sort | while read -r e; do emit_one "$e"; done
  fi
}

cmd_recalc() {
  local email="${1:?email required}"
  require_email "$email"
  doveadm quota recalc -u "$email"
  echo "ok: recalculated quota for $email"
}

# --- suspend / unsuspend ----------------------------------------------------

# Rebuild the user line with $new_extra in field 8. Awk handles the case where
# the existing extra contained colons (e.g. userdb_quota_rule=*:storage=1G)
# by collecting fields 8..NF — same trick cmd_passwd uses.
write_extra_field() {
  local email="$1" new_extra="$2" existing="$3"
  printf '%s\n' "$existing" | awk -F: -v ex="$new_extra" 'BEGIN{OFS=":"} {
    print $1,$2,$3,$4,$5,$6,$7,ex
  }'
}

cmd_suspend() {
  local email="${1:?email required}"
  require_email "$email"
  local existing; existing=$(grep "^$email:" "$USERS" || true)
  [ -n "$existing" ] || { echo "no such mailbox: $email"; exit 1; }
  if is_suspended_line "$existing"; then
    echo "already suspended: $email"; return 0
  fi

  # Capture the original Argon2id hash so unsuspend can restore it.
  local orig_hash; orig_hash=$(printf '%s\n' "$existing" | awk -F: '{print $2}')
  local prior_extra; prior_extra=$(printf '%s\n' "$existing" | awk -F: 'BEGIN{OFS=":"} {n=NF; out=$8; for(i=9;i<=n;i++) out=out":"$i; print out}')

  # Compose new extras: keep whatever was there, append prior_hash + suspend
  # marker. Argon2 PHC encoding has no spaces, so the value is safe to embed
  # in a space-separated extras field.
  local new_extra="$prior_extra"
  [ -n "$new_extra" ] && new_extra="$new_extra "
  new_extra="${new_extra}prior_hash=${orig_hash} ${SUSPEND_TOKEN}"

  # Replace field 2 (hash) with the sentinel so password::verify always fails.
  local rebuilt; rebuilt=$(printf '%s\n' "$existing" | awk -F: -v h="$SUSPEND_HASH_SENTINEL" -v ex="$new_extra" 'BEGIN{OFS=":"} { print $1,h,$3,$4,$5,$6,$7,ex }')

  sed -i "\|^$email:|d" "$USERS"
  echo "$rebuilt" >> "$USERS"
  doveadm reload >/dev/null 2>&1 || true
  echo "ok: $email suspended (auth rejected; mail still delivers)"
}

cmd_unsuspend() {
  local email="${1:?email required}"
  require_email "$email"
  local existing; existing=$(grep "^$email:" "$USERS" || true)
  [ -n "$existing" ] || { echo "no such mailbox: $email"; exit 1; }
  if ! is_suspended_line "$existing"; then
    echo "not suspended: $email"; return 0
  fi

  local prior_extra; prior_extra=$(printf '%s\n' "$existing" | awk -F: 'BEGIN{OFS=":"} {n=NF; out=$8; for(i=9;i<=n;i++) out=out":"$i; print out}')

  # Pull prior_hash=<value> out (value runs until next space or end).
  local restored_hash=""
  if [[ "$prior_extra" =~ (^|[[:space:]])prior_hash=([^[:space:]]+) ]]; then
    restored_hash="${BASH_REMATCH[2]}"
  fi
  if [ -z "$restored_hash" ]; then
    echo "no prior_hash on $email — cannot unsuspend safely. Use 'mailbox passwd' to set a fresh password." >&2
    exit 1
  fi

  # Strip both markers + collapse whitespace.
  local new_extra="$prior_extra"
  new_extra=$(echo "$new_extra" | sed -E 's/(^|[[:space:]])prior_hash=[^[:space:]]+//g')
  new_extra=$(strip_suspend_token "$new_extra")

  local rebuilt; rebuilt=$(printf '%s\n' "$existing" | awk -F: -v h="$restored_hash" -v ex="$new_extra" 'BEGIN{OFS=":"} { print $1,h,$3,$4,$5,$6,$7,ex }')

  sed -i "\|^$email:|d" "$USERS"
  echo "$rebuilt" >> "$USERS"
  doveadm reload >/dev/null 2>&1 || true
  echo "ok: $email unsuspended"
}

# --- Phase 3: vacation auto-responder -------------------------------------
# --- vacation auto-responder ------------------------------------------------

# vacation_dir <email> — print the maildir root for the user (validated).
# Errors out if the directory doesn't exist; refuses to create paths
# outside the vmail tree.
vacation_dir() {
  local email="$1"
  require_email "$email"
  local local_p; local_p=$(local_part "$email")
  local domain;  domain=$(domain_of "$email")
  local dir="$VMAIL_BASE/$domain/$local_p"
  [ -d "$dir" ] || { echo "no maildir for $email (run: mailbox add $email)" >&2; exit 1; }
  echo "$dir"
}

# sieve_escape — backslash-escape `\` and `"` so the value is safe to embed
# in a Sieve double-quoted string literal. Sieve string literals follow the
# same escape rules as JSON for these two chars; everything else is literal.
sieve_escape() {
  local s="${1-}"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf '%s' "$s"
}

# generate_vacation_sieve <subject> <body> [start] [end]
# Emits a self-contained Sieve script using the `vacation` extension.
# Subject + body are escaped; start/end (if both present) become a
# `currentdate :value` guard so replies only fire inside the window.
generate_vacation_sieve() {
  local subject="$1" body="$2" start="${3:-}" end="${4:-}"
  local esc_subject esc_body
  esc_subject=$(sieve_escape "$subject")
  esc_body=$(sieve_escape "$body")

  if [ -n "$start" ] && [ -n "$end" ]; then
    cat <<SIEVE
require ["vacation", "date", "relational"];
if allof (currentdate :value "ge" "date" "$start",
          currentdate :value "le" "date" "$end") {
  vacation
    :days 1
    :subject "$esc_subject"
    "$esc_body";
}
SIEVE
  else
    cat <<SIEVE
require ["vacation"];
vacation
  :days 1
  :subject "$esc_subject"
  "$esc_body";
SIEVE
  fi
}

cmd_vacation() {
  local email="${1:?email required}"; shift || true
  local action="${1:-}"; shift || true
  require_email "$email"

  local dir; dir=$(vacation_dir "$email")
  local sieve_dir="$dir/sieve"
  local script="$sieve_dir/vacation.sieve"
  local active="$dir/.dovecot.sieve"

  case "$action" in
    enable)
      [ -f "$script" ] || { echo "no vacation.sieve for $email — run 'mailbox vacation $email set ...' first" >&2; exit 1; }
      ln -sfn "sieve/vacation.sieve" "$active"
      chown -h vmail:vmail "$active" 2>/dev/null || true
      echo "ok: vacation enabled for $email"
      ;;
    disable)
      rm -f "$active"
      echo "ok: vacation disabled for $email"
      ;;
    set)
      local subject="${1:?subject required}"
      local body="${2:?body required}"
      local start="${3:-}" end="${4:-}"
      if [ -n "$start" ] && ! [[ "$start" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
        echo "bad start date: $start (use YYYY-MM-DD)" >&2; exit 1
      fi
      if [ -n "$end" ] && ! [[ "$end" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
        echo "bad end date: $end (use YYYY-MM-DD)" >&2; exit 1
      fi
      install -d -o vmail -g vmail -m 0700 "$sieve_dir"
      local tmp; tmp=$(mktemp)
      generate_vacation_sieve "$subject" "$body" "$start" "$end" > "$tmp"
      install -o vmail -g vmail -m 0600 "$tmp" "$script"
      rm -f "$tmp"
      echo "ok: vacation script written for $email"
      ;;
    *)
      echo "usage: mailbox vacation EMAIL {enable|disable|set SUBJECT BODY [START END]}" >&2
      exit 2
      ;;
  esac
}

cmd_vacation_status() {
  local email="${1:?email required}"
  require_email "$email"
  local local_p; local_p=$(local_part "$email")
  local domain;  domain=$(domain_of "$email")
  local active="$VMAIL_BASE/$domain/$local_p/.dovecot.sieve"
  if [ -L "$active" ] || [ -f "$active" ]; then
    echo "enabled"
  else
    echo "disabled"
  fi
}


# --- Phase 5: sieve filters (inbox rules) ----------------------------------
# --- sieve filters (inbox rules) -------------------------------------------
#
# Storage layout (per mailbox):
#   /var/mail/vmail/<domain>/<local>/sieve/filters.sieve   ← the rules file
#   /var/mail/vmail/<domain>/<local>/.dovecot.sieve        ← active script
#
# filters.sieve is a managed TSV-with-comments file: each rule is a `# RULE`
# comment line carrying the structured TSV (so we can round-trip without
# parsing Sieve), followed by the equivalent Sieve `if ... { ... }` block.
# Phase 3's vacation logic, if/when active, writes its own script and we
# stitch them together via an `include` in `.dovecot.sieve`.
#
# Field syntax:
#   from              → Sieve `address :is "From"`
#   subject           → Sieve `header :contains "Subject"`
#   header:X-Name     → Sieve `header :contains "X-Name"`
# Action syntax:
#   move FOLDER       → fileinto "FOLDER";  (requires "fileinto")
#   tag TAG           → addflag  "TAG";     (requires "imap4flags")
#   forward EMAIL     → redirect "EMAIL";
#   discard           → discard;

sieve_dir_for() {
  local email="$1"
  local local=$(local_part "$email") domain=$(domain_of "$email")
  echo "$VMAIL_BASE/$domain/$local/sieve"
}

filters_path_for() { echo "$(sieve_dir_for "$1")/filters.sieve"; }
active_link_for() {
  local email="$1"
  local local=$(local_part "$email") domain=$(domain_of "$email")
  echo "$VMAIL_BASE/$domain/$local/.dovecot.sieve"
}

# sieve_escape escapes a string for inclusion inside Sieve "..." literals.
# Sieve quoted strings escape backslash and double-quote with a backslash.
sieve_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf '%s' "$s"
}

# require_field validates the FIELD argument.
require_field() {
  case "$1" in
    from|subject) return 0 ;;
    header:*)
      local name="${1#header:}"
      [[ "$name" =~ ^[A-Za-z0-9-]+$ ]] || { echo "bad header name: $name"; exit 1; }
      ;;
    *) echo "bad field: $1 (use from|subject|header:X-NAME)"; exit 1 ;;
  esac
}

require_action() {
  case "$1" in
    move|tag|forward|discard) return 0 ;;
    *) echo "bad action: $1 (use move|tag|forward|discard)"; exit 1 ;;
  esac
}

# Render a single rule's Sieve block (no `require` — that's emitted once).
render_rule_block() {
  local field="$1" value="$2" action="$3" arg="$4"
  local test
  case "$field" in
    from)    test="address :is \"From\" \"$(sieve_escape "$value")\"" ;;
    subject) test="header :contains \"Subject\" \"$(sieve_escape "$value")\"" ;;
    header:*) test="header :contains \"$(sieve_escape "${field#header:}")\" \"$(sieve_escape "$value")\"" ;;
  esac
  local body
  case "$action" in
    move)    body="fileinto \"$(sieve_escape "$arg")\";" ;;
    tag)     body="addflag \"$(sieve_escape "$arg")\";" ;;
    forward) body="redirect \"$(sieve_escape "$arg")\";" ;;
    discard) body="discard;" ;;
  esac
  printf 'if %s {\n  %s\n  stop;\n}\n' "$test" "$body"
}

# Rebuild filters.sieve from the array of `field<TAB>value<TAB>action<TAB>arg`
# lines passed via stdin (one per line). Order in = order out.
write_filters_file() {
  local email="$1"
  local dir; dir=$(sieve_dir_for "$email")
  local file; file=$(filters_path_for "$email")
  install -d -o vmail -g vmail -m 0700 "$dir"

  local tmp; tmp=$(mktemp)
  {
    echo "# managed: filters — edited by /usr/local/bin/mailbox; manual edits are kept"
    echo "# but rules tagged '# RULE\\t...' are owned by the CLI."
    echo 'require ["fileinto","imap4flags"];'
    echo
    while IFS=$'\t' read -r field value action arg; do
      [ -z "${field:-}" ] && continue
      printf '# RULE\t%s\t%s\t%s\t%s\n' "$field" "$value" "$action" "$arg"
      render_rule_block "$field" "$value" "$action" "$arg"
      echo
    done
  } > "$tmp"
  install -o vmail -g vmail -m 0600 "$tmp" "$file"
  rm -f "$tmp"

  # Activate filters.sieve unless another script is already linked. If a
  # script is already linked (e.g. Phase 3 vacation), don't clobber it —
  # the operator can stitch them together via an `include "filters";`.
  local link; link=$(active_link_for "$email")
  if [ ! -e "$link" ]; then
    ln -sf "sieve/filters.sieve" "$link"
    chown -h vmail:vmail "$link" 2>/dev/null || true
  fi

  # Compile so Dovecot picks up changes immediately.
  sievec "$file" 2>/dev/null || true
}

# Read existing rules from filters.sieve. Each `# RULE` line carries the
# canonical TSV; lines without that tag are user-edited Sieve and are
# preserved (but not surfaced in the list — power users edit raw Sieve).
read_filters_tsv() {
  local file="$1"
  [ -f "$file" ] || return 0
  awk -F'\t' '/^# RULE\t/ {
    sub(/^# RULE\t/, "")
    print
  }' "$file"
}

cmd_filter_list() {
  local email="${1:?email required}"
  require_email "$email"
  local file; file=$(filters_path_for "$email")
  local id=0
  read_filters_tsv "$file" | while IFS= read -r line; do
    id=$((id+1))
    printf '%d\t%s\n' "$id" "$line"
  done
}

cmd_filter_add() {
  local email="${1:?email required}"
  local field="${2:?field required}"
  local value="${3:?value required}"
  local action="${4:?action required}"
  local arg="${5:-}"
  require_email "$email"
  require_field "$field"
  require_action "$action"
  if [ "$action" != "discard" ] && [ -z "$arg" ]; then
    echo "action $action requires an argument"; exit 1
  fi

  local file; file=$(filters_path_for "$email")
  local tmp; tmp=$(mktemp)
  printf '%s\t%s\t%s\t%s\n' "$field" "$value" "$action" "$arg" > "$tmp"
  if [ -f "$file" ]; then
    read_filters_tsv "$file" >> "$tmp"
  fi
  write_filters_file "$email" < "$tmp"
  rm -f "$tmp"
  echo "ok: rule added for $email"
}

cmd_filter_del() {
  local email="${1:?email required}"
  local id="${2:?id required}"
  require_email "$email"
  [[ "$id" =~ ^[0-9]+$ ]] || { echo "bad id: $id"; exit 1; }

  local file; file=$(filters_path_for "$email")
  [ -f "$file" ] || { echo "no filters file for $email"; exit 1; }

  local tmp; tmp=$(mktemp)
  awk -F'\t' -v drop="$id" 'BEGIN{n=0} /^# RULE\t/ {
    n++
    if (n != drop) {
      sub(/^# RULE\t/, "")
      print
    }
    next
  }' "$file" > "$tmp"
  write_filters_file "$email" < "$tmp"
  rm -f "$tmp"
  echo "ok: rule $id deleted for $email"
}


# --- Phase 6: spam settings ------------------------------------------------
# --- spam settings ---------------------------------------------------------
#
# State is stored as a single managed Sieve script per mailbox at
#   $VMAIL_BASE/<domain>/<local>/sieve/spam.sieve
# Header sentinels embed the lists + threshold so we can round-trip:
#   # managed: spam
#   # whitelist: a@b.com,c@d.com
#   # blacklist: x@y.com
#   # threshold: 8.0      (or absent if unset)
# The active script at .dovecot.sieve `include`s "spam" (and, if a Phase 5
# "filters" file exists, "filters" too — both files coexist).

spam_dir_for() {
  local email="$1"
  local local_p; local_p=$(local_part "$email")
  local domain; domain=$(domain_of "$email")
  echo "$VMAIL_BASE/$domain/$local_p/sieve"
}
spam_file_for() { echo "$(spam_dir_for "$1")/spam.sieve"; }
active_sieve_for() {
  local email="$1"
  local local_p; local_p=$(local_part "$email")
  local domain; domain=$(domain_of "$email")
  echo "$VMAIL_BASE/$domain/$local_p/.dovecot.sieve"
}

# sieve_quote ESCAPED — emit a string safe to drop inside Sieve double-quotes.
# Sieve string syntax allows backslash-escapes for `\\` and `\"`; everything
# else is literal. Reject any control char to keep the file ASCII-clean.
sieve_quote() {
  local s="$1"
  if [[ "$s" =~ [[:cntrl:]] ]]; then
    echo "bad input (control char): $s" >&2; exit 1
  fi
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf '%s' "$s"
}

# parse_spam_state EMAIL — sets globals SPAM_WL, SPAM_BL, SPAM_TH from the
# sentinels in the existing spam.sieve (or empty defaults).
parse_spam_state() {
  local f; f=$(spam_file_for "$1")
  SPAM_WL=""
  SPAM_BL=""
  SPAM_TH=""
  [ -f "$f" ] || return 0
  SPAM_WL=$(awk -F': ' '/^# whitelist:/ {sub(/^# whitelist: */,""); print; exit}' "$f" 2>/dev/null || true)
  SPAM_BL=$(awk -F': ' '/^# blacklist:/ {sub(/^# blacklist: */,""); print; exit}' "$f" 2>/dev/null || true)
  SPAM_TH=$(awk -F': ' '/^# threshold:/ {sub(/^# threshold: */,""); print; exit}' "$f" 2>/dev/null || true)
}

# write_spam_sieve EMAIL WHITELIST_CSV BLACKLIST_CSV THRESHOLD
write_spam_sieve() {
  local email="$1" wl="${2:-}" bl="${3:-}" th="${4:-}"
  require_email "$email"
  grep -q "^$email:" "$USERS" || { echo "no such mailbox: $email"; exit 1; }
  local local_p; local_p=$(local_part "$email")
  local domain; domain=$(domain_of "$email")
  local dir; dir=$(spam_dir_for "$email")
  local file; file=$(spam_file_for "$email")
  install -d -o vmail -g vmail -m 0700 "$dir"

  local require="\"fileinto\""
  local need_envelope=0
  local rules=""

  if [ -n "$wl" ] || [ -n "$bl" ]; then
    need_envelope=1
  fi

  # Whitelist: short-circuit to INBOX (skips later blacklist + threshold).
  if [ -n "$wl" ]; then
    local addrs=""
    local IFS=','
    for a in $wl; do
      a="${a## }"; a="${a%% }"
      [ -z "$a" ] && continue
      [ -n "$addrs" ] && addrs="$addrs, "
      addrs="$addrs\"$(sieve_quote "$a")\""
    done
    unset IFS
    if [ -n "$addrs" ]; then
      rules+=$'if envelope :is "from" ['"$addrs"$']{\n  fileinto "INBOX";\n  stop;\n}\n'
    fi
  fi

  # Blacklist: divert to Junk.
  if [ -n "$bl" ]; then
    local addrs=""
    local IFS=','
    for a in $bl; do
      a="${a## }"; a="${a%% }"
      [ -z "$a" ] && continue
      [ -n "$addrs" ] && addrs="$addrs, "
      addrs="$addrs\"$(sieve_quote "$a")\""
    done
    unset IFS
    if [ -n "$addrs" ]; then
      rules+=$'if envelope :is "from" ['"$addrs"$']{\n  fileinto "Junk";\n  stop;\n}\n'
    fi
  fi

  # Threshold: requires the relational + comparator-i;ascii-numeric extensions,
  # plus a header check on X-Spam-Score (rspamd writes this when active).
  local extras=""
  if [ -n "$th" ] && [ "$th" != "none" ]; then
    if ! [[ "$th" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
      echo "bad threshold: $th (use a non-negative number, or 'none')"; exit 1
    fi
    extras='"comparator-i;ascii-numeric", "relational"'
    rules+=$'if header :value "ge" :comparator "i;ascii-numeric" "X-Spam-Score" "'"$th"$'"{\n  fileinto "Junk";\n  stop;\n}\n'
  fi

  local req_list="$require"
  [ "$need_envelope" -eq 1 ] && req_list="$req_list, \"envelope\""
  [ -n "$extras" ] && req_list="$req_list, $extras"

  {
    echo "# managed: spam"
    echo "# whitelist: $wl"
    echo "# blacklist: $bl"
    if [ -n "$th" ] && [ "$th" != "none" ]; then
      echo "# threshold: $th"
    fi
    echo "require [$req_list];"
    echo ""
    printf '%s' "$rules"
  } > "$file"
  chown vmail:vmail "$file"
  chmod 0600 "$file"

  ensure_active_sieve_includes "$email"

  # Recompile so Dovecot's LDA picks up the new script next delivery.
  sievec "$file" >/dev/null 2>&1 || true
}

# ensure_active_sieve_includes EMAIL — make $email's .dovecot.sieve `include`
# both filters (Phase 5) and spam (Phase 6) if those managed files exist.
# Idempotent.
ensure_active_sieve_includes() {
  local email="$1"
  local active; active=$(active_sieve_for "$email")
  local dir_owner; dir_owner=$(dirname "$active")
  local sdir; sdir=$(spam_dir_for "$email")
  local has_filters=0 has_spam=0
  [ -f "$sdir/filters.sieve" ] && has_filters=1
  [ -f "$sdir/spam.sieve" ] && has_spam=1

  # If both are absent, leave any existing user-edited script alone.
  if [ "$has_filters" -eq 0 ] && [ "$has_spam" -eq 0 ]; then
    return 0
  fi

  {
    echo "# managed: include"
    echo "require [\"include\"];"
    [ "$has_filters" -eq 1 ] && echo 'include :personal "filters";'
    [ "$has_spam" -eq 1 ]    && echo 'include :personal "spam";'
  } > "$active"
  chown vmail:vmail "$active" 2>/dev/null || true
  chmod 0600 "$active" 2>/dev/null || true
  sievec "$active" >/dev/null 2>&1 || true
}

# csv_remove CSV ITEM — print CSV with ITEM removed (case-insensitive match).
csv_remove() {
  local csv="$1" item="$2"
  local out=""
  local IFS=','
  for a in $csv; do
    a="${a## }"; a="${a%% }"
    [ -z "$a" ] && continue
    if [ "${a,,}" = "${item,,}" ]; then continue; fi
    [ -n "$out" ] && out="$out,"
    out="$out$a"
  done
  unset IFS
  printf '%s' "$out"
}

# csv_add CSV ITEM — append ITEM to CSV unless already present (case-insensitive).
csv_add() {
  local csv="$1" item="$2"
  local IFS=','
  for a in $csv; do
    a="${a## }"; a="${a%% }"
    if [ "${a,,}" = "${item,,}" ]; then
      unset IFS
      printf '%s' "$csv"
      return
    fi
  done
  unset IFS
  if [ -z "$csv" ]; then
    printf '%s' "$item"
  else
    printf '%s,%s' "$csv" "$item"
  fi
}

cmd_spam_list() {
  local email="${1:?email required}"
  require_email "$email"
  parse_spam_state "$email"
  echo "whitelist:${SPAM_WL}"
  echo "blacklist:${SPAM_BL}"
  if [ -z "$SPAM_TH" ]; then
    echo "threshold:none"
  else
    echo "threshold:${SPAM_TH}"
  fi
}

cmd_spam_allow() {
  local email="${1:?email required}" addr="${2:?addr required}"
  require_email "$email"
  parse_spam_state "$email"
  SPAM_WL=$(csv_add "$SPAM_WL" "$addr")
  write_spam_sieve "$email" "$SPAM_WL" "$SPAM_BL" "$SPAM_TH"
  echo "ok: whitelisted $addr for $email"
}

cmd_spam_block() {
  local email="${1:?email required}" addr="${2:?addr required}"
  require_email "$email"
  parse_spam_state "$email"
  SPAM_BL=$(csv_add "$SPAM_BL" "$addr")
  write_spam_sieve "$email" "$SPAM_WL" "$SPAM_BL" "$SPAM_TH"
  echo "ok: blacklisted $addr for $email"
}

cmd_spam_unallow() {
  local email="${1:?email required}" addr="${2:?addr required}"
  require_email "$email"
  parse_spam_state "$email"
  SPAM_WL=$(csv_remove "$SPAM_WL" "$addr")
  write_spam_sieve "$email" "$SPAM_WL" "$SPAM_BL" "$SPAM_TH"
  echo "ok: removed $addr from whitelist for $email"
}

cmd_spam_unblock() {
  local email="${1:?email required}" addr="${2:?addr required}"
  require_email "$email"
  parse_spam_state "$email"
  SPAM_BL=$(csv_remove "$SPAM_BL" "$addr")
  write_spam_sieve "$email" "$SPAM_WL" "$SPAM_BL" "$SPAM_TH"
  echo "ok: removed $addr from blacklist for $email"
}

cmd_spam_threshold() {
  local email="${1:?email required}" score="${2:-}"
  require_email "$email"
  parse_spam_state "$email"
  if [ -z "$score" ] || [ "$score" = "none" ]; then
    SPAM_TH=""
  else
    if ! [[ "$score" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
      echo "bad threshold: $score (use a non-negative number, or 'none')"; exit 1
    fi
    SPAM_TH="$score"
  fi
  write_spam_sieve "$email" "$SPAM_WL" "$SPAM_BL" "$SPAM_TH"
  echo "ok: threshold for $email = ${SPAM_TH:-none}"
}


usage() {
  sed -n '/^# mailbox/,/^set -e/p' "$0" | sed 's/^# *//; /^$/q'
  exit 2
}

# Only dispatch when invoked directly — `source mailbox` skips this so
# the helpers can be unit-tested standalone.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  require_root
  case "${1:-}" in
    add)     shift; cmd_add "$@" ;;
    passwd)  shift; cmd_passwd "$@" ;;
    del)     shift; cmd_del "$@" ;;
    alias)   shift; cmd_alias "$@" ;;
    unalias) shift; cmd_unalias "$@" ;;
    list)    cmd_list ;;
    quota)   shift; cmd_quota "$@" ;;
    usage)   shift; cmd_usage "$@" ;;
    recalc)  shift; cmd_recalc "$@" ;;
    suspend) shift; cmd_suspend "$@" ;;
    unsuspend) shift; cmd_unsuspend "$@" ;;
    vacation) shift; cmd_vacation "$@" ;;
    vacation-status) shift; cmd_vacation_status "$@" ;;
    filter-list) shift; cmd_filter_list "$@" ;;
    filter-add)  shift; cmd_filter_add "$@" ;;
    filter-del)  shift; cmd_filter_del "$@" ;;
    spam-list)      shift; cmd_spam_list "$@" ;;
    spam-allow)     shift; cmd_spam_allow "$@" ;;
    spam-block)     shift; cmd_spam_block "$@" ;;
    spam-unallow)   shift; cmd_spam_unallow "$@" ;;
    spam-unblock)   shift; cmd_spam_unblock "$@" ;;
    spam-threshold) shift; cmd_spam_threshold "$@" ;;
    *)       usage ;;
  esac
fi
