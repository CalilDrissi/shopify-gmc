#!/usr/bin/env bash
# mailbox — manage Dovecot + Postfix virtual mailboxes on shopifygmc.com.
#
#   mailbox add EMAIL [PASSWORD]   create a mailbox (random pw if omitted)
#   mailbox passwd EMAIL [PASSWORD]   change password (random pw if omitted)
#   mailbox del EMAIL              delete a mailbox + its Maildir
#   mailbox alias FROM TO          alias FROM → TO (TO can be a real
#                                  mailbox, an external address, or another
#                                  alias)
#   mailbox unalias FROM           remove an alias
#   mailbox list                   list mailboxes + aliases
#   mailbox quota EMAIL [SIZE]     set per-mailbox quota (1G, 500M, 0=unlimited;
#                                  empty = remove override → falls back to default)
#   mailbox usage [EMAIL]          print TSV email<TAB>used_bytes<TAB>quota_bytes
#                                  (one line per mailbox, or just EMAIL if given)
#   mailbox recalc EMAIL           wraps doveadm quota recalc — repairs maildirsize
#   mailbox suspend EMAIL          reject auth (mail still delivers; data preserved)
#   mailbox unsuspend EMAIL        re-enable auth
set -euo pipefail

DOMAIN_RE='^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$'
USERS=/etc/dovecot/users
VMAILBOX=/etc/postfix/vmailbox
VIRTUAL=/etc/postfix/virtual
VMAIL_BASE=/var/mail/vmail
DEFAULT_QUOTA=1G   # cPanel-default-style 1GB; admin can override per-mailbox

require_root() {
  [ "$EUID" -eq 0 ] || { echo "must run as root"; exit 1; }
}
require_email() {
  [[ "$1" =~ $DOMAIN_RE ]] || { echo "not a valid email: $1"; exit 1; }
}
gen_pw() {
  openssl rand -base64 27 | tr -d '/+=' | tr -d 'O0Il' | cut -c1-24
}
local_part() { echo "$1" | cut -d@ -f1; }
domain_of()  { echo "$1" | cut -d@ -f2; }

# parse_size_to_bytes "1G" → 1073741824, "500M" → 524288000, "0" → 0
parse_size_to_bytes() {
  local s="${1:-}"
  [ -z "$s" ] && { echo 0; return; }
  case "$s" in
    *[Kk]) echo $(( ${s%[Kk]} * 1024 )) ;;
    *[Mm]) echo $(( ${s%[Mm]} * 1024 * 1024 )) ;;
    *[Gg]) echo $(( ${s%[Gg]} * 1024 * 1024 * 1024 )) ;;
    *[Tt]) echo $(( ${s%[Tt]} * 1024 * 1024 * 1024 * 1024 )) ;;
    *)     echo "$s" ;;
  esac
}

# extract_quota_size <user line> — pulls the SIZE token from
# "userdb_quota_rule=*:storage=1G" and prints "1G"; empty if not set.
extract_quota_size() {
  local line="$1"
  if [[ "$line" =~ userdb_quota_rule=\*:storage=([0-9]+[KMGTkmgt]?) ]]; then
    echo "${BASH_REMATCH[1]}"
  fi
}

# Compose a line's 8th field. If $1 is non-empty, sets the quota rule;
# if empty, no rule (Dovecot's plugin defaults apply).
quota_field_for() {
  local size="${1:-}"
  if [ -z "$size" ] || [ "$size" = "0" ]; then
    echo ""
  else
    echo "userdb_quota_rule=*:storage=$size"
  fi
}

# Suspend tokens live alongside quota rules in the 8th field.
# Dovecot's passwd-file parser separates multiple extra fields by whitespace;
# `nopassword=y` tells the passdb the user has no valid password, so auth is
# rejected while the userdb entry (and Maildir delivery) keeps working.
SUSPEND_TOKEN='nopassword=y'

is_suspended_line() {
  local line="$1"
  [[ "$line" == *"$SUSPEND_TOKEN"* ]]
}

# add_suspend_token <existing 8th-field value> — appends nopassword=y if absent.
add_suspend_token() {
  local extra="${1:-}"
  if [[ "$extra" == *"$SUSPEND_TOKEN"* ]]; then
    echo "$extra"; return
  fi
  if [ -z "$extra" ]; then
    echo "$SUSPEND_TOKEN"
  else
    echo "$extra $SUSPEND_TOKEN"
  fi
}

# strip_suspend_token <existing 8th-field value> — removes nopassword=y, then
# normalises whitespace so a stray double-space doesn't sneak back in.
strip_suspend_token() {
  local extra="${1:-}"
  extra="${extra//$SUSPEND_TOKEN/}"
  extra="$(echo "$extra" | tr -s ' ' | sed 's/^ //; s/ $//')"
  echo "$extra"
}

cmd_add() {
  local email="${1:?email required}" pw="${2:-}"
  require_email "$email"
  local local=$(local_part "$email") domain=$(domain_of "$email")
  if grep -q "^$email:" "$USERS"; then
    echo "already exists: $email (use 'mailbox passwd' to change)"; exit 1
  fi
  [ -z "$pw" ] && pw=$(gen_pw)

  local hash; hash=$(doveadm pw -s ARGON2ID -p "$pw")
  local extra; extra=$(quota_field_for "$DEFAULT_QUOTA")
  echo "$email:$hash:5000:5000::$VMAIL_BASE/$domain/$local::$extra" >> "$USERS"
  install -d -o vmail -g vmail -m 0700 "$VMAIL_BASE/$domain/$local"

  echo "$email    $domain/$local/" >> "$VMAILBOX"
  postmap "$VMAILBOX"

  echo "ok: $email created"
  echo "    password: $pw"
  echo "    quota:    $DEFAULT_QUOTA"
  echo "    (record the password — not retrievable later)"
}

cmd_passwd() {
  local email="${1:?email required}" pw="${2:-}"
  require_email "$email"
  local existing; existing=$(grep "^$email:" "$USERS" || true)
  [ -n "$existing" ] || { echo "no such mailbox: $email"; exit 1; }
  [ -z "$pw" ] && pw=$(gen_pw)
  local hash; hash=$(doveadm pw -s ARGON2ID -p "$pw")

  # Preserve the existing 8th-field (quota override etc.) across rotation —
  # otherwise rotating a password silently erases per-mailbox quota.
  local prior_extra; prior_extra=$(printf '%s\n' "$existing" | awk -F: 'BEGIN{OFS=":"} {n=NF; out=$8; for(i=9;i<=n;i++) out=out":"$i; print out}')
  local local=$(local_part "$email") domain=$(domain_of "$email")

  sed -i "\|^$email:|d" "$USERS"
  echo "$email:$hash:5000:5000::$VMAIL_BASE/$domain/$local::$prior_extra" >> "$USERS"
  echo "ok: password rotated for $email"
  echo "    new password: $pw"
}

cmd_del() {
  local email="${1:?email required}"
  require_email "$email"
  read -p "permanently delete $email and its mail? [type the email to confirm] " confirm
  [ "$confirm" = "$email" ] || { echo "aborted"; exit 1; }
  local local=$(local_part "$email") domain=$(domain_of "$email")
  sed -i "\|^$email:|d" "$USERS"
  sed -i "\|^$email\\s|d" "$VMAILBOX"
  postmap "$VMAILBOX"
  rm -rf "$VMAIL_BASE/$domain/$local"
  echo "ok: $email deleted"
}

cmd_alias() {
  local from="${1:?from required}" to="${2:?to required}"
  require_email "$from"
  # Remove old entry if present, then append
  sed -i "\|^$from\\s|d" "$VIRTUAL"
  echo "$from    $to" >> "$VIRTUAL"
  postmap "$VIRTUAL"
  echo "ok: $from → $to"
}

cmd_unalias() {
  local from="${1:?from required}"
  sed -i "\|^$from\\s|d" "$VIRTUAL"
  postmap "$VIRTUAL"
  echo "ok: removed alias for $from"
}

cmd_list() {
  echo "=== mailboxes ==="
  awk -F: '{print "  " $1}' "$USERS" | sort
  echo ""
  echo "=== aliases ==="
  awk 'NF==2 {printf "  %-35s → %s\n", $1, $2}' "$VIRTUAL" | sort
}

# --- quota / usage / recalc -------------------------------------------------

cmd_quota() {
  local email="${1:?email required}" size="${2:-}"
  require_email "$email"
  local existing; existing=$(grep "^$email:" "$USERS" || true)
  [ -n "$existing" ] || { echo "no such mailbox: $email"; exit 1; }

  # Validate size syntax: digits + optional K/M/G/T, or 0, or empty
  if [ -n "$size" ] && [ "$size" != "0" ] && ! [[ "$size" =~ ^[0-9]+[KMGTkmgt]?$ ]]; then
    echo "bad size: $size (use 1G, 500M, 2K, 0=unlimited, or empty=default)"; exit 1
  fi

  # Rebuild the line's 8th field with the new quota rule, preserving the
  # rest of the line via awk.
  local extra; extra=$(quota_field_for "$size")
  local rebuilt; rebuilt=$(printf '%s\n' "$existing" | awk -F: -v ex="$extra" 'BEGIN{OFS=":"} { print $1,$2,$3,$4,$5,$6,$7,ex }')

  sed -i "\|^$email:|d" "$USERS"
  echo "$rebuilt" >> "$USERS"

  # Force Dovecot to pick up the new rule + recalc the mailbox's usage so
  # the next read sees the correct ratio.
  doveadm reload >/dev/null 2>&1 || true
  doveadm quota recalc -u "$email" 2>/dev/null || true

  echo "ok: quota for $email = ${size:-default ($DEFAULT_QUOTA)}"
}

# Read the maildirsize file and return the integer used-bytes.
# Dovecot maildirsize format:
#   line 1: <quota_bytes>S[<quota_count>C]   ← QUOTA header, not usage
#   line 2+: <bytes> <msgs>                  ← absolute baseline (after recalc)
#            +<add_bytes> <add_msgs>         ← deltas on delivery
#            -<sub_bytes> <sub_msgs>         ← deltas on expunge
# We SKIP line 1 (it's the quota cap, not a usage value) and sum the leading
# signed integer of each subsequent line.
maildirsize_used_bytes() {
  local path="$1"
  [ -f "$path" ] || { echo 0; return; }
  awk 'BEGIN { used = 0 }
       NR==1 { next }
       NF>=1 { used += $1 }
       END   { print (used<0) ? 0 : used+0 }' "$path"
}

cmd_usage() {
  local one="${1:-}"
  emit_one() {
    local email="$1"
    local local=$(local_part "$email") domain=$(domain_of "$email")
    local user_line; user_line=$(grep "^$email:" "$USERS" || true)
    local size_token; size_token=$(extract_quota_size "$user_line")
    [ -z "$size_token" ] && size_token="$DEFAULT_QUOTA"
    local quota_bytes; quota_bytes=$(parse_size_to_bytes "$size_token")
    local used; used=$(maildirsize_used_bytes "$VMAIL_BASE/$domain/$local/maildirsize")
    printf '%s\t%s\t%s\n' "$email" "$used" "$quota_bytes"
  }

  if [ -n "$one" ]; then
    require_email "$one"
    grep -q "^$one:" "$USERS" || { echo "no such mailbox: $one"; exit 1; }
    emit_one "$one"
  else
    awk -F: '{print $1}' "$USERS" | sort | while read -r e; do emit_one "$e"; done
  fi
}

cmd_recalc() {
  local email="${1:?email required}"
  require_email "$email"
  doveadm quota recalc -u "$email"
  echo "ok: recalculated quota for $email"
}

# --- suspend / unsuspend ----------------------------------------------------

# Rebuild the user line with $new_extra in field 8. Awk handles the case where
# the existing extra contained colons (e.g. userdb_quota_rule=*:storage=1G)
# by collecting fields 8..NF — same trick cmd_passwd uses.
write_extra_field() {
  local email="$1" new_extra="$2" existing="$3"
  printf '%s\n' "$existing" | awk -F: -v ex="$new_extra" 'BEGIN{OFS=":"} {
    print $1,$2,$3,$4,$5,$6,$7,ex
  }'
}

cmd_suspend() {
  local email="${1:?email required}"
  require_email "$email"
  local existing; existing=$(grep "^$email:" "$USERS" || true)
  [ -n "$existing" ] || { echo "no such mailbox: $email"; exit 1; }

  local prior_extra; prior_extra=$(printf '%s\n' "$existing" | awk -F: 'BEGIN{OFS=":"} {n=NF; out=$8; for(i=9;i<=n;i++) out=out":"$i; print out}')
  local new_extra; new_extra=$(add_suspend_token "$prior_extra")
  local rebuilt; rebuilt=$(write_extra_field "$email" "$new_extra" "$existing")

  sed -i "\|^$email:|d" "$USERS"
  echo "$rebuilt" >> "$USERS"
  doveadm reload >/dev/null 2>&1 || true
  echo "ok: $email suspended (auth rejected; mail still delivers)"
}

cmd_unsuspend() {
  local email="${1:?email required}"
  require_email "$email"
  local existing; existing=$(grep "^$email:" "$USERS" || true)
  [ -n "$existing" ] || { echo "no such mailbox: $email"; exit 1; }

  local prior_extra; prior_extra=$(printf '%s\n' "$existing" | awk -F: 'BEGIN{OFS=":"} {n=NF; out=$8; for(i=9;i<=n;i++) out=out":"$i; print out}')
  local new_extra; new_extra=$(strip_suspend_token "$prior_extra")
  local rebuilt; rebuilt=$(write_extra_field "$email" "$new_extra" "$existing")

  sed -i "\|^$email:|d" "$USERS"
  echo "$rebuilt" >> "$USERS"
  doveadm reload >/dev/null 2>&1 || true
  echo "ok: $email unsuspended"
}

usage() {
  sed -n '/^# mailbox/,/^set -e/p' "$0" | sed 's/^# *//; /^$/q'
  exit 2
}

# Only dispatch when invoked directly — `source mailbox` skips this so
# the helpers can be unit-tested standalone.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  require_root
  case "${1:-}" in
    add)     shift; cmd_add "$@" ;;
    passwd)  shift; cmd_passwd "$@" ;;
    del)     shift; cmd_del "$@" ;;
    alias)   shift; cmd_alias "$@" ;;
    unalias) shift; cmd_unalias "$@" ;;
    list)    cmd_list ;;
    quota)   shift; cmd_quota "$@" ;;
    usage)   shift; cmd_usage "$@" ;;
    recalc)  shift; cmd_recalc "$@" ;;
    suspend) shift; cmd_suspend "$@" ;;
    unsuspend) shift; cmd_unsuspend "$@" ;;
    *)       usage ;;
  esac
fi
