---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopAppBar from '../components/TopAppBar.astro';
import Hero from '../components/Hero.astro';
import ProblemCards from '../components/ProblemCards.astro';
import Pricing from '../components/Pricing.astro';
import SeeWhatWeSee from '../components/SeeWhatWeSee.astro';
import WhatsAtStake from '../components/WhatsAtStake.astro';
import HowItWorks from '../components/HowItWorks.astro';
import WhatWeCheck from '../components/WhatWeCheck.astro';
import Outcome from '../components/Outcome.astro';
import Testimonials from '../components/Testimonials.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---
