---
interface Props { caption?: string; }
const { caption = 'Your storefront — what shoppers see' } = Astro.props;
const products = [
  { title: 'Aero Pro headphones', price: '$129', flag: false, img: 'https://images.pexels.com/photos/3756879/pexels-photo-3756879.jpeg?auto=compress&cs=tinysrgb&w=400' },
  { title: 'Studio over-ear', price: '$189', flag: true, img: 'https://images.pexels.com/photos/3394650/pexels-photo-3394650.jpeg?auto=compress&cs=tinysrgb&w=400' },
  { title: 'Daily commuter buds', price: '$79', flag: false, img: 'https://images.pexels.com/photos/8534088/pexels-photo-8534088.jpeg?auto=compress&cs=tinysrgb&w=400' },
];
---
<div>
  {caption && (
    <div class="mb-3 inline-flex pill bg-md-tertiary-container text-md-on-surface shadow-m3-1">{caption}</div>
  )}
  <div class="rounded-m3-lg overflow-hidden border border-md-outline-variant bg-md-surface-container-lowest">
    <div class="bg-[#1a1a1a] text-white px-4 py-2 text-xs flex items-center justify-between">
      <span>Shopify storefront · Theme: Dawn 12.0</span>
      <span class="opacity-60">Live</span>
    </div>
    <div class="px-4 py-3 border-b border-md-outline-variant flex items-center justify-between">
      <span class="font-medium">Acme Audio</span>
      <div class="flex gap-3 text-sm text-md-on-surface-variant">
        <span>Shop</span><span>Catalog</span><span>About</span>
      </div>
    </div>
    <div class="p-5">
      <div class="rounded-m3-md overflow-hidden mb-4 aspect-[16/7] bg-md-surface-container">
        <img
          src="https://images.pexels.com/photos/1337753/pexels-photo-1337753.jpeg?auto=compress&cs=tinysrgb&w=1200"
          alt="hero" loading="lazy" width="800" height="350" class="w-full h-full object-cover"
        />
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {products.map((p) => (
          <div class="relative">
            <div class="aspect-square rounded-md bg-md-surface-container overflow-hidden">
              <img src={p.img} alt={p.title} loading="lazy" width="200" height="200" class="w-full h-full object-cover" />
            </div>
            <div class="text-xs mt-1 line-clamp-1">{p.title}</div>
            <div class="text-sm font-medium">{p.price}</div>
            {p.flag && (
              <span class="absolute top-1.5 right-1.5 w-6 h-6 rounded-full bg-md-error text-white text-xs flex items-center justify-center font-bold" aria-label="Flagged">!</span>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
