---
const nav = [
  { href: '#how-it-works', label: 'How it works' },
  { href: '#what-we-check', label: 'Checks' },
  { href: '/pricing', label: 'Pricing' },
  { href: '#testimonials', label: 'Customers' },
];
---
<header class="sticky top-0 z-40 backdrop-blur-md bg-md-surface/80 border-b border-md-outline-variant">
  <div class="container-page flex items-center justify-between gap-3 h-16">
    <a href="/" class="flex items-center gap-2 font-semibold text-md-on-surface min-w-0" aria-label="shopifygmc home">
      <svg viewBox="0 0 32 32" class="w-7 h-7 shrink-0" aria-hidden="true">
        <defs>
          <linearGradient id="topbar-mark" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#008060"/>
            <stop offset="1" stop-color="#005a44"/>
          </linearGradient>
        </defs>
        <rect width="32" height="32" rx="8" ry="8" fill="url(#topbar-mark)"/>
        <path d="M9 16.6 13.4 21 23 11.4" fill="none" stroke="#9af5cd" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="truncate">shopifygmc</span>
    </a>
    <nav class="hidden md:flex items-center gap-7 body-md text-md-on-surface-variant">
      {nav.map((n) => <a href={n.href} class="hover:text-md-on-surface transition-colors">{n.label}</a>)}
    </nav>
    <div class="flex items-center gap-2 shrink-0">
      <a href="/login" class="hidden sm:inline-flex btn-text">Sign in</a>
      <a href="/signup" class="btn-filled px-4 sm:px-6 text-sm sm:text-base whitespace-nowrap">
        <span class="sm:hidden">Audit free</span>
        <span class="hidden sm:inline">Start free audit</span>
      </a>
      <details class="md:hidden relative">
        <summary class="list-none cursor-pointer w-10 h-10 flex items-center justify-center -mr-2" aria-label="Open menu">
          <svg viewBox="0 0 24 24" class="w-6 h-6" aria-hidden="true"><path fill="currentColor" d="M3 6h18v2H3zM3 11h18v2H3zM3 16h18v2H3z"/></svg>
        </summary>
        <div class="fixed left-0 right-0 top-16 bg-md-surface-container-lowest border-b border-md-outline-variant p-6 flex flex-col gap-4 shadow-m3-3">
          {nav.map((n) => <a href={n.href} class="body-lg">{n.label}</a>)}
          <a href="/login" class="body-lg">Sign in</a>
        </div>
      </details>
    </div>
  </div>
</header>
