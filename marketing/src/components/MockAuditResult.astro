---
const issues = [
  { sku: 'SKU-1041', issue: 'Missing GTIN', severity: 'critical' },
  { sku: 'SKU-1078', issue: 'Image too small (96×96)', severity: 'critical' },
  { sku: 'SKU-2003', issue: 'Title contains "Sale 50% off"', severity: 'warning' },
  { sku: 'SKU-2014', issue: 'Description < 70 chars', severity: 'warning' },
];
---
<div>
  <div class="mb-3 inline-flex pill bg-md-primary-container text-md-on-primary-container shadow-m3-1">
    Live audit example · acmeaudio.com
  </div>
  <div class="rounded-m3-lg overflow-hidden border border-md-outline-variant bg-md-surface-container-lowest shadow-m3-3">
    <!-- chrome bar -->
    <div class="bg-[#f1f3f4] px-4 py-2 flex items-center gap-1.5 border-b border-md-outline-variant">
      <span class="w-3 h-3 rounded-full bg-[#ff5f56]" aria-hidden="true"></span>
      <span class="w-3 h-3 rounded-full bg-[#ffbd2e]" aria-hidden="true"></span>
      <span class="w-3 h-3 rounded-full bg-[#27c93f]" aria-hidden="true"></span>
      <div class="ml-3 flex-1 bg-white rounded-md px-3 py-1 text-xs text-[#5f6368] truncate">shopifygmc.com/audits/12kx9</div>
    </div>
    <!-- header -->
    <div class="px-5 py-4 border-b border-md-outline-variant flex items-center justify-between">
      <div>
        <div class="label-md text-md-on-surface-variant uppercase">Audit complete</div>
        <div class="font-semibold text-md-on-surface mt-0.5">acmeaudio.com</div>
      </div>
      <span class="pill bg-md-primary-container text-md-on-primary-container">
        <svg viewBox="0 0 24 24" class="w-3.5 h-3.5" aria-hidden="true"><path fill="currentColor" d="m9 16.2-3.5-3.5L4 14.2l5 5 11-11-1.5-1.5z"/></svg>
        29 / 29 checks
      </span>
    </div>
    <!-- stats -->
    <div class="grid grid-cols-3 divide-x divide-md-outline-variant border-b border-md-outline-variant">
      <div class="p-4 text-center">
        <div class="text-2xl sm:text-3xl font-semibold text-md-error">3</div>
        <div class="label-md text-md-on-surface-variant mt-1">Critical</div>
      </div>
      <div class="p-4 text-center">
        <div class="text-2xl sm:text-3xl font-semibold text-[#92400e]">9</div>
        <div class="label-md text-md-on-surface-variant mt-1">Warnings</div>
      </div>
      <div class="p-4 text-center">
        <div class="text-2xl sm:text-3xl font-semibold text-md-primary">412</div>
        <div class="label-md text-md-on-surface-variant mt-1">Approved</div>
      </div>
    </div>
    <!-- issues list -->
    <ul class="divide-y divide-md-outline-variant">
      {issues.map((it) => (
        <li class="px-5 py-3 flex items-center justify-between gap-3">
          <div class="min-w-0">
            <div class="font-mono text-xs text-md-on-surface-variant">{it.sku}</div>
            <div class="body-md truncate">{it.issue}</div>
          </div>
          {it.severity === 'critical'
            ? <span class="pill bg-md-error-container text-md-on-error-container shrink-0">Critical</span>
            : <span class="pill bg-[#fef3c7] text-[#92400e] shrink-0">Warning</span>}
        </li>
      ))}
    </ul>
    <!-- footer CTA -->
    <div class="px-5 py-3 border-t border-md-outline-variant flex items-center justify-between bg-md-surface-container-low">
      <span class="body-sm text-md-on-surface-variant">12 AI-generated fixes ready</span>
      <span class="pill bg-md-primary text-md-on-primary">View report →</span>
    </div>
  </div>
</div>
