---
interface Product {
  title: string;
  price: string;
  store: string;
  img: string;
}
interface Props {
  products: Product[];
  caption?: string;
  approvedIndex?: number;
  suspendedIndex?: number;
  query?: string;
}
const { products, caption, approvedIndex, suspendedIndex, query = 'wireless headphones' } = Astro.props;
---
<div>
  {caption && (
    <div class="mb-3 inline-flex pill bg-md-primary-container text-md-on-primary-container shadow-m3-1">{caption}</div>
  )}
  <div class="rounded-m3-lg overflow-hidden border border-md-outline-variant bg-md-surface-container-lowest">
    <div class="bg-[#f1f3f4] px-4 py-2 flex items-center gap-1.5 border-b border-md-outline-variant">
      <span class="w-3 h-3 rounded-full bg-[#ff5f56]" aria-hidden="true"></span>
      <span class="w-3 h-3 rounded-full bg-[#ffbd2e]" aria-hidden="true"></span>
      <span class="w-3 h-3 rounded-full bg-[#27c93f]" aria-hidden="true"></span>
      <div class="ml-3 flex-1 min-w-0 bg-white rounded-md px-3 py-1 text-xs text-[#5f6368] truncate">google.com/search?q={query}&tbm=shop</div>
    </div>
    <div class="px-4 sm:px-6 py-5">
      <div class="flex items-center gap-3 sm:gap-6 mb-3">
        <span class="text-2xl font-medium tracking-tight shrink-0" aria-hidden="true">
          <span style="color:#4285F4">G</span><span style="color:#EA4335">o</span><span style="color:#FBBC05">o</span><span style="color:#4285F4">g</span><span style="color:#34A853">l</span><span style="color:#EA4335">e</span>
        </span>
        <div class="flex-1 min-w-0 h-9 rounded-full border border-[#dadce0] flex items-center px-4 text-sm text-[#202124] truncate">{query}</div>
      </div>
      <div class="flex gap-5 border-b border-[#dadce0] text-sm mb-3 -mx-2 px-2 overflow-x-auto">
        {['All', 'Shopping', 'Images', 'Videos', 'News'].map((t) => (
          <span class:list={[
            'whitespace-nowrap pb-2 border-b-2 -mb-px',
            t === 'Shopping' ? 'border-[#1a73e8] text-[#1a73e8] font-medium' : 'border-transparent text-[#5f6368]'
          ]}>{t}</span>
        ))}
      </div>
      <div class="flex items-center justify-between mb-2 text-[11px] text-[#5f6368]">
        <span>Sponsored · About 1,840,000 results</span>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 pt-3">
        {products.map((p, i) => (
          <div class:list={[
            'gshop relative rounded-md border bg-white p-2',
            i === approvedIndex ? 'border-md-primary ring-2 ring-md-primary/40' : 'border-[#dadce0]',
            i === suspendedIndex ? 'gshop--suspended' : '',
          ]}>
            {i === approvedIndex && (
              <span class="absolute -top-2.5 left-1/2 -translate-x-1/2 z-10 pill bg-md-primary text-md-on-primary text-[10px] h-5 px-2 shadow-sm whitespace-nowrap">
                <svg viewBox="0 0 24 24" class="w-3 h-3" aria-hidden="true"><path fill="currentColor" d="m9 16.2-3.5-3.5L4 14.2l5 5 11-11-1.5-1.5z"/></svg>
                Your store
              </span>
            )}
            {i === suspendedIndex && (
              <span class="absolute -top-2.5 left-1/2 -translate-x-1/2 z-10 pill bg-md-error text-white text-[10px] h-5 px-2 shadow-sm whitespace-nowrap">Suspended</span>
            )}
            <div class="aspect-square bg-md-surface-container rounded mb-2 overflow-hidden">
              <img src={p.img} alt={p.title} loading="lazy" decoding="async" class="w-full h-full object-cover" />
            </div>
            <div class="text-xs text-[#202124] line-clamp-2 leading-snug min-h-[32px]">{p.title}</div>
            <div class="text-sm font-medium mt-1" style="color:#202124">{p.price}</div>
            <div class="text-xs text-[#5f6368] truncate">{p.store}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .gshop--suspended {
    background-image: repeating-linear-gradient(135deg, rgba(217, 48, 37, 0.18) 0 8px, transparent 8px 18px);
    opacity: 0.85;
  }
  .gshop--suspended img { filter: grayscale(0.6); }
</style>
