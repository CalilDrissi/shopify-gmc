---
interface Props { caption?: string; }
const { caption = 'What Google sees' } = Astro.props;
const issues = [
  { sku: 'SKU-1041', issue: 'Missing GTIN', severity: 'critical' },
  { sku: 'SKU-1078', issue: 'Image too small (< 100×100)', severity: 'critical' },
  { sku: 'SKU-1112', issue: 'Price mismatch with landing page', severity: 'critical' },
  { sku: 'SKU-2003', issue: 'Title contains promotional text', severity: 'warning' },
  { sku: 'SKU-2014', issue: 'Description shorter than 70 chars', severity: 'warning' },
];
---
<div>
  {caption && (
    <div class="mb-3 inline-flex pill bg-md-error-container text-md-on-error-container shadow-m3-1">{caption}</div>
  )}
  <div class="rounded-m3-lg overflow-hidden border border-md-outline-variant bg-md-surface-container-lowest">
    <div class="bg-[#f1f3f4] px-4 py-2 flex items-center gap-1.5 border-b border-md-outline-variant">
      <span class="w-3 h-3 rounded-full bg-[#ff5f56]" aria-hidden="true"></span>
      <span class="w-3 h-3 rounded-full bg-[#ffbd2e]" aria-hidden="true"></span>
      <span class="w-3 h-3 rounded-full bg-[#27c93f]" aria-hidden="true"></span>
      <div class="ml-3 flex-1 bg-white rounded-md px-3 py-1 text-xs text-[#5f6368] truncate">merchants.google.com/diagnostics</div>
    </div>
    <div class="bg-[#1a73e8] text-white px-4 py-2 flex items-center justify-between text-sm">
      <span class="font-medium">Merchant Center · Diagnostics</span>
      <span class="opacity-80 text-xs">acme-audio</span>
    </div>
    <div class="bg-md-error-container border-l-4 border-md-error text-md-on-error-container px-4 py-3 text-sm flex items-center gap-2">
      <svg viewBox="0 0 24 24" class="w-5 h-5" aria-hidden="true"><path fill="currentColor" d="M12 2 1 21h22L12 2Zm0 6 7.5 13h-15L12 8Zm-1 5v3h2v-3h-2Zm0 4v2h2v-2h-2Z"/></svg>
      <span><strong>3 critical issues</strong> are preventing your products from showing in Google Shopping.</span>
    </div>
    <div class="grid grid-cols-3 gap-3 p-4 border-b border-md-outline-variant">
      <div class="rounded-m3-md p-3 bg-md-error-container">
        <div class="text-xs text-md-on-error-container">Disapproved</div>
        <div class="text-2xl font-semibold text-md-on-error-container">38</div>
      </div>
      <div class="rounded-m3-md p-3 bg-[#fef3c7]">
        <div class="text-xs text-[#92400e]">Warnings</div>
        <div class="text-2xl font-semibold text-[#92400e]">14</div>
      </div>
      <div class="rounded-m3-md p-3 bg-md-primary-container">
        <div class="text-xs text-md-on-primary-container">Approved</div>
        <div class="text-2xl font-semibold text-md-on-primary-container">412</div>
      </div>
    </div>
    <table class="w-full text-sm">
      <thead class="text-xs text-md-on-surface-variant">
        <tr>
          <th class="text-left px-4 py-2 font-medium">SKU</th>
          <th class="text-left px-4 py-2 font-medium">Issue</th>
          <th class="text-right px-4 py-2 font-medium">Severity</th>
        </tr>
      </thead>
      <tbody>
        {issues.map((it) => (
          <tr class="border-t border-md-outline-variant">
            <td class="px-4 py-2 font-mono text-xs">{it.sku}</td>
            <td class="px-4 py-2">{it.issue}</td>
            <td class="px-4 py-2 text-right">
              {it.severity === 'critical'
                ? <span class="pill bg-md-error-container text-md-on-error-container">Critical</span>
                : <span class="pill bg-[#fef3c7] text-[#92400e]">Warning</span>}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>
