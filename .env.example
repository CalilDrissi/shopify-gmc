# Application
APP_ENV=development
APP_BASE_URL=http://localhost:8080
APP_PORT=8080
APP_SECRET=replace-me-with-32-random-bytes

# PostgreSQL
DATABASE_URL=postgres://gmc:gmc@localhost:5432/gmcauditor?sslmode=disable

# SMTP (Mailhog in dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@gmcauditor.local

# Shopify OAuth
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,read_inventory,read_product_listings
SHOPIFY_REDIRECT_URL=http://localhost:8080/auth/shopify/callback

# Anthropic (for AI fix suggestions)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Gumroad
GUMROAD_PRODUCT_ID=
GUMROAD_WEBHOOK_SECRET=
GUMROAD_LICENSE_VERIFY_URL=https://api.gumroad.com/v2/licenses/verify
